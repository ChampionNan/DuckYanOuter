# name: test/sql/optimizer/outer_yan/fallback.test
# description: OuterYan optimizer — non-applicable queries fall back to the
#              baseline JOIN_ORDER pipeline. Asserts that for each rejection
#              shape, results are identical with OuterYan enabled vs disabled.
#              Counterpart to acyclic_query.test: A1 asserts the optimizer is
#              NOT firing; here we assert results stay correct under fallback.
# group: [outer_yan]

statement ok
PRAGMA enable_verification

statement ok
PRAGMA verify_parallelism

statement ok
CREATE TABLE a(id INTEGER, ax INTEGER);

statement ok
CREATE TABLE b(id INTEGER, bx INTEGER);

statement ok
CREATE TABLE c(id INTEGER, cx INTEGER);

statement ok
CREATE TABLE d(id INTEGER, dx INTEGER);

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30), (4, 40);

statement ok
INSERT INTO b VALUES (1, 100), (2, 200), (3, 300), (5, 500);

statement ok
INSERT INTO c VALUES (1, 1000), (3, 3000), (4, 4000);

statement ok
INSERT INTO d VALUES (2, 20000), (3, 30000), (5, 50000);

# ============================================================================
# Each block runs the query twice — OuterYan enabled, then disabled — and
# pins both result sets. Identical expected blocks prove fallback correctness.
# ============================================================================

# Pure-INNER 2-relation join (gate rejects, falls through).
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx FROM a JOIN b ON a.id = b.id
----
1	100
2	200
3	300

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx FROM a JOIN b ON a.id = b.id
----
1	100
2	200
3	300

# Pure-INNER 3-relation chain.
statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a JOIN b ON a.id = b.id JOIN c ON b.id = c.id
----
1	100	1000
3	300	3000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a JOIN b ON a.id = b.id JOIN c ON b.id = c.id
----
1	100	1000
3	300	3000

# 2-relation LEFT OUTER (rejected for too-few-relations).
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx FROM a LEFT JOIN b ON a.id = b.id
----
1	100
2	200
3	300
4	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx FROM a LEFT JOIN b ON a.id = b.id
----
1	100
2	200
3	300
4	NULL

# Theta predicate.
statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.id, c.id
FROM a LEFT JOIN b ON a.id < b.id LEFT JOIN c ON a.id = c.id
----
1	2	1
1	3	1
1	5	1
2	3	NULL
2	5	NULL
3	5	3
4	5	4

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.id, c.id
FROM a LEFT JOIN b ON a.id < b.id LEFT JOIN c ON a.id = c.id
----
1	2	1
1	3	1
1	5	1
2	3	NULL
2	5	NULL
3	5	3
4	5	4

# Expression on join key.
statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.id, c.cx
FROM a LEFT JOIN b ON a.id + 1 = b.id LEFT JOIN c ON a.id = c.id
----
1	2	1000
2	3	NULL
3	NULL	3000
4	5	4000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.id, c.cx
FROM a LEFT JOIN b ON a.id + 1 = b.id LEFT JOIN c ON a.id = c.id
----
1	2	1000
2	3	NULL
3	NULL	3000
4	5	4000

# IS NOT DISTINCT FROM (NULL-tolerant predicate, rejected).
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id IS NOT DISTINCT FROM b.id
----
1	100
2	200
3	300
4	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id IS NOT DISTINCT FROM b.id
----
1	100
2	200
3	300
4	NULL

# SEMI join (EXISTS).
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id
WHERE EXISTS (SELECT 1 FROM c WHERE c.id = a.id)
----
1	100
3	300
4	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id
WHERE EXISTS (SELECT 1 FROM c WHERE c.id = a.id)
----
1	100
3	300
4	NULL

# ANTI join (NOT EXISTS).
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id
WHERE NOT EXISTS (SELECT 1 FROM c WHERE c.id = a.id)
----
2	200

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id
WHERE NOT EXISTS (SELECT 1 FROM c WHERE c.id = a.id)
----
2	200

# UNION ALL above outer-join skeleton.
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx FROM a LEFT JOIN b ON a.id = b.id
UNION ALL
SELECT a.id, c.cx FROM a LEFT JOIN c ON a.id = c.id
----
1	100
1	1000
2	200
2	NULL
3	300
3	3000
4	4000
4	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx FROM a LEFT JOIN b ON a.id = b.id
UNION ALL
SELECT a.id, c.cx FROM a LEFT JOIN c ON a.id = c.id
----
1	100
1	1000
2	200
2	NULL
3	300
3	3000
4	4000
4	NULL

# Window function above outer-join skeleton.
statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, ROW_NUMBER() OVER (PARTITION BY a.id ORDER BY a.id) AS rn
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
1	100	1
2	200	1
3	300	1
4	NULL	1

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, ROW_NUMBER() OVER (PARTITION BY a.id ORDER BY a.id) AS rn
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
1	100	1
2	200	1
3	300	1
4	NULL	1

# Cyclic join graph (a-b, a-c, b-c all present).
statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON b.id = c.id AND a.id = c.id
----
1	100	1000
2	200	NULL
3	300	3000
4	NULL	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON b.id = c.id AND a.id = c.id
----
1	100	1000
2	200	NULL
3	300	3000
4	NULL	NULL

# Cross product (no condition between b and c).
statement ok
SET disabled_optimizers TO ''

query I
SELECT COUNT(*) FROM a LEFT JOIN b ON a.id = b.id, c
----
12

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query I
SELECT COUNT(*) FROM a LEFT JOIN b ON a.id = b.id, c
----
12

# Correlated subquery in WHERE.
statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id
WHERE a.ax = (SELECT MAX(c.cx) FROM c WHERE c.id = a.id) / 1000 * 10
----
1	100
3	300
4	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id
WHERE a.ax = (SELECT MAX(c.cx) FROM c WHERE c.id = a.id) / 1000 * 10
----
1	100
3	300
4	NULL

