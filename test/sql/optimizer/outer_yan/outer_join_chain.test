# ============================================================================
# Variant 7 — 5-relation star (one fact + 4 dim tables, all LEFT). Each dim
# attaches to the same fact column → join graph is a star.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query IIIII rowsort
SELECT a.id, b.bx, c.cx, d.dx, e.ex
FROM a LEFT JOIN b ON a.id = b.id
     LEFT JOIN c ON a.id = c.id
     LEFT JOIN d ON a.id = d.id
     LEFT JOIN e ON a.id = e.id
----
1	100	1000	NULL	100000
2	200	NULL	20000	NULL
3	300	3000	30000	NULL
4	NULL	4000	NULL	400000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query IIIII rowsort
SELECT a.id, b.bx, c.cx, d.dx, e.ex
FROM a LEFT JOIN b ON a.id = b.id
     LEFT JOIN c ON a.id = c.id
     LEFT JOIN d ON a.id = d.id
     LEFT JOIN e ON a.id = e.id
----
1	100	1000	NULL	100000
2	200	NULL	20000	NULL
3	300	3000	30000	NULL
4	NULL	4000	NULL	400000

