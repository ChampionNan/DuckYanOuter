# name: test/sql/optimizer/outer_yan/outer_join_chain.test
# description: OuterYan optimizer — outer-join chain semantics. Validates that
#              NULL-padding behavior is preserved across the LEFT/RIGHT/FULL
#              variants, residual filters, and chain lengths 3..5. Every block
#              runs with OuterYan enabled and disabled; the row multisets must
#              match exactly (including NULL counts).
# group: [outer_yan]

statement ok
PRAGMA enable_verification

statement ok
PRAGMA verify_parallelism

statement ok
CREATE TABLE a(id INTEGER, ax INTEGER);

statement ok
CREATE TABLE b(id INTEGER, bx INTEGER);

statement ok
CREATE TABLE c(id INTEGER, cx INTEGER);

statement ok
CREATE TABLE d(id INTEGER, dx INTEGER);

statement ok
CREATE TABLE e(id INTEGER, ex INTEGER);

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30), (4, 40);

statement ok
INSERT INTO b VALUES (1, 100), (2, 200), (3, 300), (5, 500);

statement ok
INSERT INTO c VALUES (1, 1000), (3, 3000), (4, 4000);

statement ok
INSERT INTO d VALUES (2, 20000), (3, 30000), (5, 50000);

statement ok
INSERT INTO e VALUES (1, 100000), (4, 400000), (5, 500000);

# ============================================================================
# Variant 1 — LEFT/LEFT chain (canonical case).
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
1	100	1000
2	200	NULL
3	300	3000
4	NULL	4000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
1	100	1000
2	200	NULL
3	300	3000
4	NULL	4000

