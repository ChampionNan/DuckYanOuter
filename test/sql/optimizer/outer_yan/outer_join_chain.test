# ============================================================================
# Variant 9 — Residual filter on a single relation.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
WHERE a.ax > 15
----
2	200	NULL
3	300	3000
4	NULL	4000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
WHERE a.ax > 15
----
2	200	NULL
3	300	3000
4	NULL	4000

# ============================================================================
# Variant 10 — Residual filter spanning two relations (must land at the
# lowest fused subplan, not at the root). Exercises step 3 of OJTToLogicalPlan.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
WHERE COALESCE(b.bx, 0) + COALESCE(c.cx, 0) > 500
----
1	100	1000
3	300	3000
4	NULL	4000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
WHERE COALESCE(b.bx, 0) + COALESCE(c.cx, 0) > 500
----
1	100	1000
3	300	3000
4	NULL	4000

# ============================================================================
# Variant 11 — Residual filter that null-rejects an outer-joined column;
# this would NORMALLY allow Simplification::Apply to convert LEFT→INNER.
# Verify the conversion is semantics-preserving.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
WHERE b.bx > 50
----
1	100	1000
2	200	NULL
3	300	3000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, b.bx, c.cx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
WHERE b.bx > 50
----
1	100	1000
2	200	NULL
3	300	3000

