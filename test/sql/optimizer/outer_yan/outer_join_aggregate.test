# name: test/sql/optimizer/outer_yan/outer_join_aggregate.test
# description: OuterYan optimizer — aggregation root selection over outer-join
#              chains. Verifies correctness across all OuterYanAggregationType
#              variants (COUNT_STAR / COUNT / SUM / MIN/MAX / DISTINCT). The
#              actual aggregate-pushdown rewrite is currently a stub
#              (aggregate_pushdown_outer.cpp:23-34), so these tests only assert
#              result equivalence with the disabled-baseline; pushdown depth
#              will be asserted once plan 4 lands.
# group: [outer_yan]

statement ok
PRAGMA enable_verification

statement ok
PRAGMA verify_parallelism

statement ok
CREATE TABLE a(id INTEGER, ax INTEGER);

statement ok
CREATE TABLE b(id INTEGER, bx INTEGER);

statement ok
CREATE TABLE c(id INTEGER, cx INTEGER);

statement ok
CREATE TABLE d(id INTEGER, dx INTEGER);

statement ok
INSERT INTO a VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

statement ok
INSERT INTO b VALUES (1, 100), (1, 110), (2, 200), (3, 300), (6, 600);

statement ok
INSERT INTO c VALUES (1, 1000), (3, 3000), (3, 3100), (4, 4000);

statement ok
INSERT INTO d VALUES (2, 20000), (3, 30000), (5, 50000), (7, 70000);

# ============================================================================
# Variant 1 — COUNT_STAR over outer-join chain (forced root case).
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query I
SELECT COUNT(*) FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
8

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query I
SELECT COUNT(*) FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
8

# ============================================================================
# Variant 2 — GROUP BY a.id with COUNT(b.col).
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, COUNT(b.bx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
----
1	2
2	1
3	1
4	0
5	0

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, COUNT(b.bx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
----
1	2
2	1
3	1
4	0
5	0

# ============================================================================
# Variant 3 — SUM with NULLs from outer joins (NULLs treated as 0 by SUM).
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, SUM(c.cx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
----
1	1000
2	NULL
3	6200
4	4000
5	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, SUM(c.cx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
----
1	1000
2	NULL
3	6200
4	4000
5	NULL

# ============================================================================
# Variant 4 — MIN/MAX over outer-joined columns.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query III rowsort
SELECT a.id, MIN(b.bx), MAX(c.cx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
----
1	100	1000
2	200	NULL
3	300	3100
4	NULL	4000
5	NULL	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query III rowsort
SELECT a.id, MIN(b.bx), MAX(c.cx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
----
1	100	1000
2	200	NULL
3	300	3100
4	NULL	4000
5	NULL	NULL

# ============================================================================
# Variant 5 — SELECT DISTINCT.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT DISTINCT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
1	100
1	110
2	200
3	300
4	NULL
5	NULL

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT DISTINCT a.id, b.bx
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
1	100
1	110
2	200
3	300
4	NULL
5	NULL

# ============================================================================
# Variant 6 — SUM with HAVING.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT a.id, SUM(c.cx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
HAVING SUM(c.cx) > 2000
----
3	6200
4	4000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT a.id, SUM(c.cx)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
GROUP BY a.id
HAVING SUM(c.cx) > 2000
----
3	6200
4	4000

# ============================================================================
# Variant 7 — COUNT(*) on 4-way chain.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query I
SELECT COUNT(*) FROM a LEFT JOIN b ON a.id = b.id
                       LEFT JOIN c ON a.id = c.id
                       LEFT JOIN d ON a.id = d.id
----
8

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query I
SELECT COUNT(*) FROM a LEFT JOIN b ON a.id = b.id
                       LEFT JOIN c ON a.id = c.id
                       LEFT JOIN d ON a.id = d.id
----
8

# ============================================================================
# Variant 8 — Aggregation with mixed LEFT/RIGHT/FULL.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query II rowsort
SELECT COALESCE(a.id, b.id), COUNT(*)
FROM a FULL OUTER JOIN b ON a.id = b.id LEFT JOIN c ON COALESCE(a.id, b.id) = c.id
GROUP BY COALESCE(a.id, b.id)
----
1	2
2	1
3	1
4	1
5	1
6	1

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query II rowsort
SELECT COALESCE(a.id, b.id), COUNT(*)
FROM a FULL OUTER JOIN b ON a.id = b.id LEFT JOIN c ON COALESCE(a.id, b.id) = c.id
GROUP BY COALESCE(a.id, b.id)
----
1	2
2	1
3	1
4	1
5	1
6	1

# ============================================================================
# Variant 9 — Aggregation column from the deepest outer-joined relation.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query I
SELECT SUM(d.dx)
FROM a LEFT JOIN b ON a.id = b.id
       LEFT JOIN c ON a.id = c.id
       LEFT JOIN d ON a.id = d.id
----
50000

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query I
SELECT SUM(d.dx)
FROM a LEFT JOIN b ON a.id = b.id
       LEFT JOIN c ON a.id = c.id
       LEFT JOIN d ON a.id = d.id
----
50000

# ============================================================================
# Variant 10 — COUNT(DISTINCT col) over outer join.
# ============================================================================

statement ok
SET disabled_optimizers TO ''

query I
SELECT COUNT(DISTINCT b.id)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
3

statement ok
SET disabled_optimizers TO 'outer_yan_pre,outer_yan_dp,outer_yan_post'

query I
SELECT COUNT(DISTINCT b.id)
FROM a LEFT JOIN b ON a.id = b.id LEFT JOIN c ON a.id = c.id
----
3

statement ok
SET disabled_optimizers TO ''

